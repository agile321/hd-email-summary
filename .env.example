# HD-Email-Summary Environment Variables
# Copy this to .env for local development
# Set these as Railway environment variables for production
#
# NOTE: No Google credentials needed here.
# Google Sheets is written by the Apps Script (gmail_nmt_logger.gs) natively.
# Railway only handles AI parsing.

# ─── REQUIRED ─────────────────────────────────────────────────────────────────

# Gemini AI API key (from Google AI Studio — same key used in orbital-blazar)
GEMINI_API_KEY=your_gemini_api_key_here

# ─── OPTIONAL ─────────────────────────────────────────────────────────────────

# Anthropic API key — only needed if Gemini is unavailable (fallback)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
